{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "test:update": "jest --updateSnapshot",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run type-check && npm run test",
    "docs:list": "python scripts/feature-map-manager.py list",
    "docs:show": "python scripts/feature-map-manager.py show",
    "docs:deps": "python scripts/feature-map-manager.py deps",
    "docs:validate": "python scripts/feature-map-manager.py validate",
    "docs:export": "python scripts/feature-map-manager.py export",
    "modules:list": "python scripts/module-manager.py list",
    "modules:show": "python scripts/module-manager.py show",
    "modules:deps": "python scripts/module-manager.py deps",
    "modules:validate": "python scripts/module-manager.py validate",
    "modules:aggregate": "python scripts/module-manager.py aggregate",
    "modules:search": "python scripts/module-manager.py search",
    "modules:feature-deps": "python scripts/module-manager.py feature-deps",
    "docs:all": "npm run docs:validate && npm run modules:validate"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^6.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
